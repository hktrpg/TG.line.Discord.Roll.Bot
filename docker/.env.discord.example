# Copy this file to docker/.env.discord before running docker compose.

mongoURL=mongodb://hktrpgadmin:change-this-password@mongodb:27017/hktrpgRollBot?authSource=admin

DISCORD_CHANNEL_SECRET=
DISCORD_CHANNEL_CLIENTID=
DISCORD_CHANNEL_GUILDID=

MASTER=
DEBUG=
# DEBUG_LOG: When true, enables *very verbose* cluster lifecycle tracing (full runtime + stacks for respawn/kill, detailed lag summaries, [Cluster Debug] logs).
# This integrates the previous DISCORD_HEARTBEAT_DEBUG flag.
# Keep off normally; only for deep debugging.
DEBUG_LOG=
TZ=Asia/Taipei
